# Copie este arquivo para .env e preencha os valores

# Chave secreta do Django (gere uma com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=sua-chave-secreta-aqui

# Ative o modo debug apenas em desenvolvimento (True/False)
DEBUG=True

# Hosts permitidos, separados por vírgula (ex.: localhost,127.0.0.1,meusite.com)
ALLOWED_HOSTS=localhost,127.0.0.1
